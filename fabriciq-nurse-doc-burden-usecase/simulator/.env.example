# Fabric Eventstream — Custom Endpoint credentials
# Get these from: Eventstream "medical_data_stream" → Custom Endpoint → Keys
EVENT_HUB_CONNECTION_STRING=Endpoint=sb://<YOUR_SERVICEBUS_NAMESPACE>.servicebus.windows.net/;SharedAccessKeyName=<YOUR_SHARED_ACCESS_KEY_NAME>;SharedAccessKey=<key>;EntityPath=<entity>
EVENT_HUB_NAME=<YOUR_EVENT_HUB_NAME>