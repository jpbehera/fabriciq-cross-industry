# Fabric Eventstream — Custom Endpoint credentials
# Get these from: Eventstream "medical_data_stream" → Custom Endpoint → Keys
EVENT_HUB_CONNECTION_STRING=Endpoint=sb://<YOUR_SERVICEBUS_NAMESPACE>.servicebus.windows.net/;SharedAccessKeyName=<YOUR_SHARED_ACCESS_KEY_NAME>;SharedAccessKey=<key>;EntityPath=<entity>
EVENT_HUB_NAME=<YOUR_EVENT_HUB_NAME>

# RECOMMENDED (Zero Trust): Use Azure Key Vault instead of storing secrets here.
# Set the Key Vault URL and store secrets as:
#   event-hub-connection-string → your Event Hub connection string
#   event-hub-name              → your Event Hub name
# AZURE_KEYVAULT_URL=https://<YOUR_VAULT_NAME>.vault.azure.net/

# For create_dashboard_api.py: Set workspace ID to avoid enumerating all workspaces
# FABRIC_WORKSPACE_ID=<YOUR_WORKSPACE_GUID>